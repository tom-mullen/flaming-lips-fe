# Per-developer 1Password config.
# Copy this file to .env.op.local and fill in your values.
# .env.op.local is gitignored.

# The `op` CLI account shorthand (run `op account list` to find yours).
OP_ACCOUNT=

# The 1Password vault that holds your `flaming-lips-fe` item.
# (e.g. "Private", "Employee", "Shared")
OP_VAULT=
