# 1Password references — rendered at runtime by scripts/dev-with-op.sh
# using $OP_VAULT and $OP_ACCOUNT from your .env.op.local.
#
# Expected 1Password item: flaming-lips-fe
# Required fields: AUTH_SECRET, CLIENT_ID, CLIENT_SECRET,
#                  NEXT_PUBLIC_API_URL, AUTH_URL

# Secrets
AUTH_SECRET=op://$OP_VAULT/flaming-lips-fe/AUTH_SECRET
AUTH_SPOTIFY_ID=op://$OP_VAULT/flaming-lips-fe/CLIENT_ID
AUTH_SPOTIFY_SECRET=op://$OP_VAULT/flaming-lips-fe/CLIENT_SECRET

# Non-secret config
NEXT_PUBLIC_API_URL=op://$OP_VAULT/flaming-lips-fe/NEXT_PUBLIC_API_URL
AUTH_URL=op://$OP_VAULT/flaming-lips-fe/AUTH_URL
